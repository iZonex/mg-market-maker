{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operator overview for the MG Market Maker engine — kill switch, PnL, SLA, risk.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Kill switch & SLA"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Active kill-switch level per symbol. 0 Normal / 1 Widen / 2 Stop / 3 Cancel / 4 Flatten / 5 Disconnect.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Normal", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Widen", "color": "yellow" } } },
            { "type": "value", "options": { "2": { "text": "Stop", "color": "orange" } } },
            { "type": "value", "options": { "3": { "text": "Cancel", "color": "red" } } },
            { "type": "value", "options": { "4": { "text": "Flatten", "color": "red" } } },
            { "type": "value", "options": { "5": { "text": "Disconnect", "color": "dark-red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 3 },
              { "color": "dark-red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mm_kill_switch_level",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "title": "Kill switch per symbol",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLA uptime %. Exchange obligations typically require ≥ 95%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "yellow", "value": 98 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mm_sla_uptime_pct",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "title": "SLA uptime",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current number of live orders per symbol.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mm_live_orders",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "title": "Live orders",
      "type": "stat"
    },
    {
      "type": "row",
      "id": 101,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "title": "PnL"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total PnL in quote asset — sum of spread capture + inventory + rebates + funding − fees.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mm_pnl_total",
          "legendFormat": "{{symbol}} total",
          "refId": "A"
        }
      ],
      "title": "Total PnL",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "PnL attribution breakdown — spread capture is the earning, inventory is the carry risk, rebates + funding are venue-side income.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" } },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "mm_pnl_spread", "legendFormat": "{{symbol}} spread", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "mm_pnl_inventory", "legendFormat": "{{symbol}} inventory", "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "mm_pnl_rebates", "legendFormat": "{{symbol}} rebates", "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "mm_pnl_funding_realised", "legendFormat": "{{symbol}} funding", "refId": "D", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "title": "PnL attribution (stacked)",
      "type": "timeseries"
    },
    {
      "type": "row",
      "id": 102,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "title": "Inventory & spreads"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Base-asset inventory per symbol. Positive = long, negative = short. Watch for sign flips and caps.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "mm_inventory", "legendFormat": "{{symbol}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "title": "Inventory (base asset)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Venue spread in basis points. Volatility-driven widening is normal; sustained > 100 bps on a major means the book is broken or circuit breaker tripped.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "mm_spread_bps", "legendFormat": "{{symbol}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "title": "Spread (bps)",
      "type": "timeseries"
    },
    {
      "type": "row",
      "id": 103,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "title": "Risk & toxicity"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "VPIN toxicity indicator. > 0.7 routinely widens the autotuner; > 0.8 means you're likely being adversely selected.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "mm_vpin", "legendFormat": "{{symbol}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "title": "VPIN",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Realised volatility (log-return, annualised). Feeds the Avellaneda reservation price and the autotuner regime detector.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 26 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "mm_volatility", "legendFormat": "{{symbol}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "title": "Realised volatility",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SOR dispatch success vs errors per venue. Any sustained error rate needs investigation — venue auth / rate limit / network.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 26 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(mm_sor_dispatch_success_total[1m])", "legendFormat": "ok {{venue}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "rate(mm_sor_dispatch_errors_total[1m])", "legendFormat": "err {{venue}}", "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ],
      "title": "SOR dispatch rate per venue",
      "type": "timeseries"
    },
    {
      "type": "row",
      "id": 104,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "title": "Latency & surveillance"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Book update latency p50 / p95 / p99 per venue. p95 > 250 ms routinely means stale quotes vs other MMs.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(mm_book_update_latency_ms_bucket[5m])) by (le, venue))",
          "legendFormat": "p50 {{venue}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(mm_book_update_latency_ms_bucket[5m])) by (le, venue))",
          "legendFormat": "p95 {{venue}}",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(mm_book_update_latency_ms_bucket[5m])) by (le, venue))",
          "legendFormat": "p99 {{venue}}",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "title": "Book update latency (ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Surveillance score per pattern (spoofing, layering, wash, quote stuffing, ...). ≥ 0.6 fires an audit alert; ≥ 0.8 typically trips the kill switch depending on your template.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "mm_surveillance_score",
          "legendFormat": "{{pattern}} / {{symbol}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "title": "Surveillance scores",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["market-maker", "trading"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
